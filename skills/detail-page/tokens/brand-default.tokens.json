{
  "$description": "Default brand tokens for the detail-page starter, in DTCG (Design Tokens Community Group) shape. OKLCH-native (no hex). The literal CSS string lives in $extensions['com.detail-page'].css for exact round-trip; the structured $value.components are there for interop. scripts/build-tokens.js compiles this into the starter's :root{--brand-*} layer (and, with --emit=theme, the @theme mapping). This is the single source of truth — edit here, regenerate, no hand-edit drift.",
  "color": {
    "surface": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.985, 0.008, 95] }, "$extensions": { "com.detail-page": { "css": "oklch(0.985 0.008 95)" } } },
    "card":    { "$type": "color", "$value": { "colorSpace": "oklch", "components": [1, 0, 0] }, "$extensions": { "com.detail-page": { "css": "oklch(1 0 0)" } } },
    "ink":     { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.205, 0.012, 275] }, "$extensions": { "com.detail-page": { "css": "oklch(0.205 0.012 275)" } } },
    "muted":   { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.520, 0.015, 270] }, "$extensions": { "com.detail-page": { "css": "oklch(0.520 0.015 270)" } } },
    "line":    { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.205, 0.012, 275], "alpha": 0.12 }, "$extensions": { "com.detail-page": { "css": "oklch(0.205 0.012 275 / 0.12)" } } },
    "primary": {
      "50":  { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.965, 0.020, 155] }, "$extensions": { "com.detail-page": { "css": "oklch(0.965 0.020 155)" } } },
      "100": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.910, 0.040, 155] }, "$extensions": { "com.detail-page": { "css": "oklch(0.910 0.040 155)" } } },
      "300": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.760, 0.075, 156] }, "$extensions": { "com.detail-page": { "css": "oklch(0.760 0.075 156)" } } },
      "500": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.560, 0.095, 156] }, "$extensions": { "com.detail-page": { "css": "oklch(0.560 0.095 156)" } } },
      "700": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.400, 0.080, 157] }, "$extensions": { "com.detail-page": { "css": "oklch(0.400 0.080 157)" } } },
      "900": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.270, 0.050, 158] }, "$extensions": { "com.detail-page": { "css": "oklch(0.270 0.050 158)" } } },
      "DEFAULT": { "$type": "color", "$value": "{color.primary.700}" }
    },
    "accent": {
      "300": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.845, 0.105, 65] }, "$extensions": { "com.detail-page": { "css": "oklch(0.845 0.105 65)" } } },
      "500": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.720, 0.160, 58] }, "$extensions": { "com.detail-page": { "css": "oklch(0.720 0.160 58)" } } },
      "700": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.605, 0.150, 50] }, "$extensions": { "com.detail-page": { "css": "oklch(0.605 0.150 50)" } } },
      "DEFAULT": { "$type": "color", "$value": "{color.accent.500}" }
    },
    "on-accent": { "$type": "color", "$value": "{color.ink}" }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": ["Black Han Sans", "Pretendard", "sans-serif"] },
    "body":    { "$type": "fontFamily", "$value": ["Pretendard", "sans-serif"] },
    "latin":   { "$type": "fontFamily", "$value": ["Space Grotesk", "Clash Display", "sans-serif"] }
  },
  "shadow": {
    "e1": { "$type": "shadow", "$value": "0 1px 2px oklch(0.20 0.02 270 / 0.06)" },
    "e2": { "$type": "shadow", "$value": "0 6px 16px oklch(0.20 0.02 270 / 0.10)" },
    "e3": { "$type": "shadow", "$value": "0 20px 48px oklch(0.20 0.02 270 / 0.16)" }
  },
  "space": {
    "$description": "8pt spacing scale (design-system SKILL §4). Compiles to --space-N. Inner gap < outer gap.",
    "4":  { "$type": "dimension", "$value": { "value": 4,  "unit": "px" }, "$extensions": { "com.detail-page": { "css": "4px" } } },
    "8":  { "$type": "dimension", "$value": { "value": 8,  "unit": "px" }, "$extensions": { "com.detail-page": { "css": "8px" } } },
    "12": { "$type": "dimension", "$value": { "value": 12, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "12px" } } },
    "16": { "$type": "dimension", "$value": { "value": 16, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "16px" } } },
    "24": { "$type": "dimension", "$value": { "value": 24, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "24px" } } },
    "32": { "$type": "dimension", "$value": { "value": 32, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "32px" } } },
    "48": { "$type": "dimension", "$value": { "value": 48, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "48px" } } },
    "64": { "$type": "dimension", "$value": { "value": 64, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "64px" } } },
    "96": { "$type": "dimension", "$value": { "value": 96, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "96px" } } }
  },
  "fontSize": {
    "$description": "Hand-picked type scale (design-system SKILL §4). Compiles to --text-N (px). Pair with lineHeight.N.",
    "12": { "$type": "dimension", "$value": { "value": 12, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "12px" } } },
    "14": { "$type": "dimension", "$value": { "value": 14, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "14px" } } },
    "16": { "$type": "dimension", "$value": { "value": 16, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "16px" } } },
    "18": { "$type": "dimension", "$value": { "value": 18, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "18px" } } },
    "20": { "$type": "dimension", "$value": { "value": 20, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "20px" } } },
    "24": { "$type": "dimension", "$value": { "value": 24, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "24px" } } },
    "30": { "$type": "dimension", "$value": { "value": 30, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "30px" } } },
    "36": { "$type": "dimension", "$value": { "value": 36, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "36px" } } },
    "48": { "$type": "dimension", "$value": { "value": 48, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "48px" } } },
    "64": { "$type": "dimension", "$value": { "value": 64, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "64px" } } }
  },
  "lineHeight": {
    "$description": "Line-heights snapped to a 4pt rhythm, one per fontSize step (design-system SKILL §4). Compiles to --leading-N.",
    "12": { "$type": "dimension", "$value": { "value": 16, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "16px" } } },
    "14": { "$type": "dimension", "$value": { "value": 20, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "20px" } } },
    "16": { "$type": "dimension", "$value": { "value": 24, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "24px" } } },
    "18": { "$type": "dimension", "$value": { "value": 28, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "28px" } } },
    "20": { "$type": "dimension", "$value": { "value": 28, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "28px" } } },
    "24": { "$type": "dimension", "$value": { "value": 32, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "32px" } } },
    "30": { "$type": "dimension", "$value": { "value": 40, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "40px" } } },
    "36": { "$type": "dimension", "$value": { "value": 44, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "44px" } } },
    "48": { "$type": "dimension", "$value": { "value": 56, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "56px" } } },
    "64": { "$type": "dimension", "$value": { "value": 72, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "72px" } } }
  },
  "radius": {
    "$description": "Radius family (design-system SKILL §4) — pick one; concentrate the soft corner where it means something. Compiles to --radius-X.",
    "sm":   { "$type": "dimension", "$value": { "value": 6,    "unit": "px" }, "$extensions": { "com.detail-page": { "css": "6px" } } },
    "md":   { "$type": "dimension", "$value": { "value": 10,   "unit": "px" }, "$extensions": { "com.detail-page": { "css": "10px" } } },
    "lg":   { "$type": "dimension", "$value": { "value": 16,   "unit": "px" }, "$extensions": { "com.detail-page": { "css": "16px" } } },
    "pill": { "$type": "dimension", "$value": { "value": 9999, "unit": "px" }, "$extensions": { "com.detail-page": { "css": "9999px" } } }
  },
  "motion": {
    "$description": "Motion tokens (design-system SKILL §4). Duration compiles to --dur-N, easing to --ease-X. Always honor prefers-reduced-motion.",
    "duration": {
      "1": { "$type": "duration", "$value": { "value": 120, "unit": "ms" }, "$extensions": { "com.detail-page": { "css": "120ms" } } },
      "2": { "$type": "duration", "$value": { "value": 200, "unit": "ms" }, "$extensions": { "com.detail-page": { "css": "200ms" } } },
      "3": { "$type": "duration", "$value": { "value": 320, "unit": "ms" }, "$extensions": { "com.detail-page": { "css": "320ms" } } }
    },
    "easing": {
      "out":    { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1],   "$extensions": { "com.detail-page": { "css": "cubic-bezier(0.2, 0, 0, 1)" } } },
      "spring": { "$type": "cubicBezier", "$value": [0.2, 0.8, 0.2, 1], "$extensions": { "com.detail-page": { "css": "cubic-bezier(0.2, 0.8, 0.2, 1)" } } }
    }
  }
}
